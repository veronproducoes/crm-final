# Banco de dados Postgres (Supabase, Railway, RDS, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/crm_veron?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-com: openssl rand -base64 32"

# Código usado uma única vez em /setup para criar o primeiro Administrador.
# Pode ser qualquer texto/senha forte que você escolher.
SETUP_SECRET="escolha-uma-frase-secreta-aqui"

# Anthropic (usada SOMENTE no backend, nunca no frontend)
ANTHROPIC_API_KEY="sk-ant-..."

# Armazenamento de arquivos (opcional em dev; local em /public/uploads por padrão)
# Se configurar Cloudflare R2 / S3 / Supabase Storage, preencha abaixo e ajuste src/lib/storage.ts
STORAGE_DRIVER="local" # local | s3
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION=""
